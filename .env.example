# ── Pattern Proof environment ─────────────────────────────────────────────
# Copy to .env and fill in. All backend/worker vars use the PP_ prefix.

# Application
PP_DEBUG=true
PP_FRONTEND_ORIGIN=http://localhost:3000
PP_PUBLIC_BASE_URL=http://localhost:8000

# Queue (Celery / Redis)
PP_REDIS_URL=redis://redis:6379/0

# Supabase (project URL + service-role key; service key bypasses RLS — server only)
PP_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PP_SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
PP_BUCKET_SCREENSHOTS=screenshots
PP_BUCKET_HTML=html
PP_BUCKET_REPORTS=reports

# LLM — Claude (agents + vision)
PP_ANTHROPIC_API_KEY=sk-ant-...
PP_CLAUDE_AGENT_MODEL=claude-sonnet-4-6
PP_CLAUDE_VISION_MODEL=claude-sonnet-4-6

# LLM — OpenAI (cheap per-page HTML parsing)
PP_OPENAI_API_KEY=sk-...
PP_CHEAP_PARSE_MODEL=gpt-4o-mini

# ML inference (YOLO) service
PP_ML_INFERENCE_URL=http://ml-inference:8001

# Apify crawler
PP_APIFY_TOKEN=apify_api_...
PP_APIFY_ACTOR=apify/website-content-crawler

# Exa web search
PP_EXA_API_KEY=...

# Notifications — Slack
PP_SLACK_BOT_TOKEN=xoxb-...
PP_SLACK_CHANNEL=#audits

# Notifications — WhatsApp via Twilio
PP_TWILIO_ACCOUNT_SID=AC...
PP_TWILIO_AUTH_TOKEN=...
PP_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PP_NOTIFY_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Crawling limits
PP_CRAWL_MAX_DEPTH=3
PP_CRAWL_MAX_PAGES=20

# Agent control
PP_AGENT_MAX_ITERATIONS=50
PP_AGENT_MAX_FEEDBACK_RETRIES=2
PP_LOW_CONFIDENCE_THRESHOLD=0.4

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
